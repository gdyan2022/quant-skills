# Wind 数据库访问配置
# 复制为 .env 后填入真实值（.env 已被 .gitignore 排除）

# ── 数据库连接 ───────────────────────────────────────────
# 支持的 dialect（必须是 dbhub 支持的数据库）：
#   mssql+pyodbc          ← Wind 官方数据库最常见（SQL Server）
#   mysql+pymysql
#   mariadb+pymysql
#   postgresql+psycopg2
#   sqlite                ← 单机测试
# ⚠️ dbhub 不支持 Oracle，不要填 oracle+cx_oracle
WIND_DB_DIALECT=mssql+pyodbc
WIND_DB_HOST=db.internal
WIND_DB_PORT=1433
WIND_DB_USER=your_user
WIND_DB_PASSWORD=your_password_here
WIND_DB_NAME=wind

# ── SQL Server 专用（可选）──────────────────────────────
# WIND_DB_SSLMODE：disable（默认，适合内网/自签证书）/ require（强制 TLS）
# WIND_DB_INSTANCE：命名实例名（如 SQLEXPRESS），普通 MSSQL 不用填
# WIND_DB_SSLMODE=disable
# WIND_DB_INSTANCE=

# ── 数据字典（在线版，默认 fallback）────────────────────
WIND_DICT_URL=https://winddict.081188.xyz
WIND_DICT_USER=admin
WIND_DICT_PASS=your_caddy_basic_auth_password

# ── 数据字典（本地版，可选但强烈推荐）───────────────────
# 指向克隆到本地的 wind_data_dict/ 目录，dict.sh 会优先走本地 grep
# 例：
#   WIND_DICT_LOCAL=/Users/gdyan/workspace/claude/wind-data-dict/wind_data_dict
WIND_DICT_LOCAL=

# ── 列表模式过滤 ────────────────────────────────────────
# dict.sh -l 默认只输出这五个库的表，适合常见订阅场景。
# 留空 = 输出全部 25 个库（共 2657 张）。
# 库名必须和字典里第一级目录完全一致，逗号分隔。
WIND_LIST_DBS=基础代码表,中国A股数据库,中国香港股票数据库,中国共同基金数据库,指数数据库
